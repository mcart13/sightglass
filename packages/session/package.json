{
  "name": "@sightglass/session",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@sightglass/core": "workspace:*",
    "@sightglass/critique": "workspace:*",
    "@sightglass/export": "workspace:*"
  },
  "scripts": {
    "build": "yarn run -T tsc -p tsconfig.json",
    "typecheck": "yarn run -T tsc -p tsconfig.json --noEmit",
    "test": "yarn run -T vitest run",
    "lint": "echo 'lint not configured for @sightglass/session yet'"
  }
}
